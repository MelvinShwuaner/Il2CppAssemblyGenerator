<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>
    <PropertyGroup>
        <PublishTrimmed>false</PublishTrimmed>
        <TrimMode>full</TrimMode>
        <SelfContained>true</SelfContained>
        <PublishSingleFile>true</PublishSingleFile>

        <!-- Size optimizations -->
        <InvariantGlobalization>true</InvariantGlobalization>
        <DebuggerSupport>false</DebuggerSupport>
        <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    </PropertyGroup>
    <ItemGroup>
      <PackageReference Include="AssetRipper.Cpp2IL.Core" Version="1.0.1" />
    </ItemGroup>

    <ItemGroup>
      <Reference Include="AsmResolver">
        <HintPath>..\..\..\..\Documents\GitHub\Il2CppInterop\Il2CppInterop.Generator\bin\Debug\net472\AsmResolver.dll</HintPath>
      </Reference>
      <Reference Include="Il2CppInterop.Common">
        <HintPath>Interop\Il2CppInterop.Common.dll</HintPath>
      </Reference>
      <Reference Include="Il2CppInterop.Generator">
        <HintPath>Interop\Il2CppInterop.Generator.dll</HintPath>
      </Reference>
      <Reference Include="Microsoft.Extensions.Logging.Abstractions">
        <HintPath>Interop\Microsoft.Extensions.Logging.Abstractions.dll</HintPath>
      </Reference>
    </ItemGroup>

</Project>
